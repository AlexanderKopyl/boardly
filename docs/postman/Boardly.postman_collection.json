{
  "info": {
    "_postman_id": "595b7d52-c94c-472a-b12d-931f3f99c29d",
    "name": "Boardly API",
    "description": "Postman collection for Boardly Symfony API. Current implemented endpoint: POST /api/auth/register. Planned auth/admin endpoints are included as placeholders based on docs/design/authentication-api-strategy.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"plainPassword\": \"{{password}}\",\n  \"name\": \"{{name}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Implemented endpoint. Creates a pending account. Note: current Symfony DTO expects `plainPassword`, not `password`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response contains accountId and status', function () {",
                  "    pm.expect(json).to.have.property('accountId');",
                  "    pm.expect(json).to.have.property('status');",
                  "});",
                  "",
                  "if (json.accountId) {",
                  "    pm.environment.set('accountId', json.accountId);",
                  "}",
                  "",
                  "if (json.status) {",
                  "    pm.environment.set('accountStatus', json.status);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "[PLANNED] Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Planned endpoint from authentication API strategy. Expected to return accessToken and set refresh_token cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "[PLANNED] Refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-CSRF-Intent",
                "value": "{{csrfIntent}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Planned endpoint. Requires refresh_token cookie in Postman cookie jar and X-CSRF-Intent header."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "[PLANNED] Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-CSRF-Intent",
                "value": "{{csrfIntent}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Planned endpoint. Should revoke current refresh session when available and clear refresh cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 204) {",
                  "    pm.environment.unset('accessToken');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "[PLANNED] Current Account",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Planned endpoint. Requires Authorization: Bearer {{accessToken}}."
          }
        }
      ]
    },
