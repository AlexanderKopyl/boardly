APP_ENV=dev
APP_SECRET=change-me-in-local-env
APP_SHARE_DIR=var/share

# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
DEFAULT_URI=http://localhost

# Default local-development values.
# Override machine-specific values in .env.local.
DATABASE_URL="postgresql://broadly:broadly@127.0.0.1:5432/broadly?serverVersion=18&charset=utf8"
MESSENGER_TRANSPORT_DSN="amqp://guest:guest@127.0.0.1:5672/%2f/messages"
REDIS_DSN="redis://127.0.0.1:6379"
OPENSEARCH_URL="http://127.0.0.1:9200"

# Non-secret local-development placeholders.
# Override with real secret values outside version control for shared/prod environments.
IDENTITY_ACCESS_JWT_SIGNING_SECRET="local-dev-jwt-signing-secret"
IDENTITY_ACCESS_REFRESH_TOKEN_HASH_SECRET="local-dev-refresh-token-hash-secret"
