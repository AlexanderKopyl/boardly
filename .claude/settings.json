{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./auth.json)",
      "Read(./**/auth.json)",
      "Read(./.npmrc)",
      "Read(./**/.npmrc)",
      "Read(./.pypirc)",
      "Read(./**/.pypirc)",
      "Read(./config/secrets/**)",
      "Read(./var/private/**)",
      "Read(./var/backups/**)",
      "Read(./var/dumps/**)",
      "Read(./storage/private/**)",
      "Read(./storage/backups/**)",
      "Read(./storage/dumps/**)",
      "Read(./**/*.sql)",
      "Read(./**/*.sql.gz)",
      "Read(./**/*.dump)",
      "Read(./**/*.bak)",
      "Read(./**/*.sqlite)",
      "Read(./**/*.sqlite3)",
      "Read(./**/*.db)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(composer require:*)",
      "Bash(composer remove:*)",
      "Bash(composer update:*)",
      "Bash(bin/console doctrine:migrations:migrate:*)",
      "Bash(bin/console doctrine:database:drop:*)",
      "Bash(docker compose:*)",
      "Bash(npx:*)",
      "Bash(git push:*)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(find . -maxdepth:*)",
      "Bash(composer validate)",
      "Bash(composer test)",
      "Bash(composer phpstan)",
      "Bash(composer qa)",
      "Bash(bin/console lint:container)",
      "Bash(bin/console lint:yaml config)",
      "Bash(bin/console debug:container:*)",
      "Bash(bin/console debug:router:*)"
    ]
  }
}
