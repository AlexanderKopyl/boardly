REDIS_DSN="redis://127.0.0.1:6379"
OPENSEARCH_URL="http://127.0.0.1:9200"

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-generate-your-own-local-secret
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
DEFAULT_URI=https://broadly.com.ua
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Local Mac/Homebrew setup: Symfony/PHP-FPM runs on the host machine.
# Use 127.0.0.1 here. Use Docker service names only when Symfony itself runs inside Docker.
DATABASE_URL="postgresql://broadly:broadly@127.0.0.1:5432/broadly?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# RabbitMQ local setup.
MESSENGER_TRANSPORT_DSN="amqp://guest:guest@127.0.0.1:5672/%2f/messages"

# Alternative local transports:
# MESSENGER_TRANSPORT_DSN="redis://127.0.0.1:6379/messages"
# MESSENGER_TRANSPORT_DSN="doctrine://default?auto_setup=0"
###< symfony/messenger ###
